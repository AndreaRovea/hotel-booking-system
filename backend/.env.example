# Copy to .env. .env is git-ignored.

PORT=3000

# SQLite database file path. Use ":memory:" for in-memory DB (good for tests).
DATABASE_PATH=./data/hotel.db

# Secret used to sign JWT access tokens. CHANGE THIS for non-dev environments.
JWT_SECRET=replace-me-with-a-long-random-string

# Access token lifetime, e.g. "1h", "30m", "7d".
JWT_EXPIRES_IN=12h
